# Streamlit Secrets Configuration
# Copy this file to secrets.toml and fill in your actual API keys

[secrets]
# OpenAI Configuration (Required for AI features)
OPENAI_API_KEY = "your_openai_api_key_here"

# Weather API (Optional)
OPENWEATHERMAP_API_KEY = "your_weather_api_key_here"

# Traffic API (Optional)
TRAFFIC_API_KEY = "your_traffic_api_key_here"

# Hugging Face (Optional)
HUGGINGFACE_API_KEY = "your_huggingface_api_key_here"

# Database Configuration (Optional)
DATABASE_URL = "sqlite:///construction_planner.db"

# App Configuration
ENVIRONMENT = "production"
DEBUG = false
