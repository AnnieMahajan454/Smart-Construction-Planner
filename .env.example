# Smart Construction Planner Environment Variables
# Copy this file to .env and fill in your actual API keys

# OpenAI Configuration (Required for AI features)
OPENAI_API_KEY=your_openai_api_key_here

# Weather API (Optional - for real-time weather data)
OPENWEATHERMAP_API_KEY=your_weather_api_key_here

# Traffic API (Optional - for real-time traffic data)
TRAFFIC_API_KEY=your_traffic_api_key_here

# Hugging Face (Optional - for alternative AI models)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Database Configuration (Optional)
DATABASE_URL=sqlite:///construction_planner.db

# App Configuration
ENVIRONMENT=production
DEBUG=false
